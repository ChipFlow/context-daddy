#!/usr/bin/env bash
# Git post-commit hook installed by context-daddy
# Updates project narrative + learnings after each commit
# Runs in background so it doesn't slow down git operations

# Find the update-context.sh script
# It could be in the plugin cache or a local dev path
CONTEXT_DADDY_SCRIPT=""

# Check common plugin cache locations
for candidate in \
    "${HOME}/.claude/plugins/cache/chipflow-context-daddy/context-daddy/"*/scripts/update-context.sh \
    "${HOME}/.claude/plugins/cache/context-daddy/"*/scripts/update-context.sh \
    "${CLAUDE_PLUGIN_ROOT:-/nonexistent}/scripts/update-context.sh"; do
    if [[ -f "${candidate}" ]]; then
        CONTEXT_DADDY_SCRIPT="${candidate}"
        break
    fi
done

# Also check if there's a path marker left by the installer
MARKER="${GIT_DIR:-.git}/../.claude/.context-daddy-path"
if [[ -z "${CONTEXT_DADDY_SCRIPT}" && -f "${MARKER}" ]]; then
    candidate="$(cat "${MARKER}")/scripts/update-context.sh"
    if [[ -f "${candidate}" ]]; then
        CONTEXT_DADDY_SCRIPT="${candidate}"
    fi
fi

if [[ -z "${CONTEXT_DADDY_SCRIPT}" ]]; then
    # Script not found - silently exit (don't break git operations)
    exit 0
fi

# Don't run if we're in a rebase or merge
if [[ -d "${GIT_DIR:-.git}/rebase-merge" ]] || [[ -d "${GIT_DIR:-.git}/rebase-apply" ]]; then
    exit 0
fi

# Don't run if already running (lockfile check)
LOCKFILE="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")/.claude/.update-context.lock"
if [[ -f "${LOCKFILE}" ]]; then
    exit 0
fi

# Run update in background, completely detached from git
(cd "$(git rev-parse --show-toplevel 2>/dev/null || echo ".")" && \
    bash "${CONTEXT_DADDY_SCRIPT}" --background --update) &>/dev/null &
disown 2>/dev/null || true

# Track commit in active goal (lightweight, no API calls)
PROJECT_TOP="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
CURRENT_GOAL_FILE="${PROJECT_TOP}/.claude/.current-goal"
if [[ -f "${CURRENT_GOAL_FILE}" ]]; then
    GOAL_UUID=$(cat "${CURRENT_GOAL_FILE}" | tr -d '[:space:]')
    COMMIT_HASH=$(git rev-parse --short HEAD)
    COMMIT_MSG=$(git log -1 --format=%s)
    GOALS_SCRIPT="$(dirname "${CONTEXT_DADDY_SCRIPT}")/goals.py"
    if [[ -f "${GOALS_SCRIPT}" ]]; then
        (cd "${PROJECT_TOP}" && uv run "${GOALS_SCRIPT}" add-commit "${GOAL_UUID}" "${COMMIT_HASH}" "${COMMIT_MSG}") &>/dev/null &
        disown 2>/dev/null || true
    fi
fi

exit 0
